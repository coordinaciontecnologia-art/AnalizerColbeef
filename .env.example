NODE_ENV=production
PORT=5009
HOST=0.0.0.0

# URL publica en la red local (cambiar IP si el servidor cambia)
PUBLIC_URL=http://192.168.20.205:5009

# Modo desarrollo local (sin login Manus) — cambiar a false en produccion
DEV_BYPASS_AUTH=true

# Base de datos MySQL
DATABASE_URL=mysql://usuario:password@host:4000/nombre_db

# Autenticacion Manus (requerido si DEV_BYPASS_AUTH=false)
JWT_SECRET=tu_jwt_secret
OAUTH_SERVER_URL=https://api.manus.im
OWNER_OPEN_ID=tu_open_id

# API Forge — IA y almacenamiento de archivos
BUILT_IN_FORGE_API_KEY=tu_api_key
BUILT_IN_FORGE_API_URL=https://forge.manus.ai

# Frontend
VITE_APP_ID=tu_app_id
VITE_APP_TITLE=Colbeef Data Analyzer
VITE_OAUTH_PORTAL_URL=https://manus.im
VITE_FRONTEND_FORGE_API_KEY=tu_frontend_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.ai
